# Server Configuration
NODE_ENV=development
# Listen on 3008 to match backend's DENTALY_SERVICE_BASE_URL default.
PORT=3008

# API Authentication — must match DENTALY_SERVICE_API_KEY in frontly-backend/.env.local
API_KEY=dentally-local-shared-secret-change-me

# Database
MONGO_URI=mongodb://localhost:27017/frontly-dentally

# Logging
LOG_FULL_PAYLOADS=true

# Metrics (60s interval)
METRICS_INTERVAL_SECS=60

# Alerting — disabled locally (no ALERT_EMAIL_SERVICE_URL)
