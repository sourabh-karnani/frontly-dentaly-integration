NODE_ENV=development
PORT=3001
API_KEY=your-frontly-internal-api-key
MONGO_URI=mongodb://localhost:27017/frontly-dentally
LOG_FULL_PAYLOADS=false

# Metrics — how often the summary log line is emitted (default 60s)
METRICS_INTERVAL_SECS=60

# Alerting — leave blank to disable. All five must be set for alerts to send.
ALERT_EMAIL_SERVICE_URL=http://localhost:3002
ALERT_EMAIL_API_KEY=your-frontly-email-api-key
ALERT_FROM=alerts@yourdomain.com
ALERT_TO=you@yourdomain.com # comma separated for multiple
ALERT_ERROR_RATE_THRESHOLD_PCT=1 # based on this the alert emails gets sent
ALERT_COOLDOWN_MINS=30
